@page "/products-old"
@rendermode InteractiveServer

<PageTitle>Product Catalog</PageTitle>

@if(!string.IsNullOrEmpty(cartMessage))
{
    <div style="background-color: #d4edda; border: 1px solid #c3e6cb; padding: 10px; margin-bottom: 15px; border-radius: 5px; color: #155724; position: relative; ">
        @cartMessage
        <button type="button" @onclick="ClearMessage" style="position: absolute; top: 5px; right: 10px; background: none; border: none; font-size: 16px; color: #155724; cursor: pointer;">&times;</button>
    </div>
}

<ProductList
    Title="Our Product Catalog"
    Products="@products"
    OnAddToCart="HandleProductAddedToCart" />


@code {
    private string cartMessage = string.Empty;
    private List<Product> products = new List<Product>
    {
        new Product { 
            Name = "Laptop", 
            Description = "High performance laptop", 
            Price = 999.99m, 
            ImageUrl = "https://via.placeholder.com/150" },

        new Product { 
            Name = "Smartphone", 
            Description = "Latest model smartphone", 
            Price = 699.99m, 
            ImageUrl = "https://via.placeholder.com/150" },

        new Product { 
            Name = "Headphones", 
            Description = "Noise-cancelling headphones", 
            Price = 199.99m, 
            ImageUrl = "https://via.placeholder.com/150" }
    };

    private void HandleProductAddedToCart(Product product)
    {
        cartMessage = $"Added '{product.Name}' to cart! Price: {product.Price:F2}";
        StateHasChanged(); // Force UI update to show the message
    }


    private void ClearMessage()
    {
        cartMessage = string.Empty;
    }
}